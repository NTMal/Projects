# ── .dockerignore ─────────────────────────────────────────────────────────────
# This file tells Docker which files to EXCLUDE when building the image.
# It works exactly like .gitignore but for Docker builds.
#
# Why this matters:
#   - Keeps the image small (don't ship notebooks, test data, git history)
#   - Speeds up builds (less data to send to Docker daemon)
#   - Avoids accidentally baking in secrets or large files

# ── Python cache files ────────────────────────────────────────────────────────
# These are auto-generated by Python and not needed in the container
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Jupyter notebooks ─────────────────────────────────────────────────────────
# Your analysis notebooks — not needed at runtime
notebooks/
*.ipynb
.ipynb_checkpoints/

# ── Data files ────────────────────────────────────────────────────────────────
# The training dataset is large (~150MB) and not needed in the image
# The models/ folder SHOULD be included (it has the .joblib files we need)
*.csv
*.parquet
/tmp/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Environment variable files ────────────────────────────────────────────────
# NEVER bake secrets into Docker images
.env
.env.local
*.env

# ── IDE and OS files ──────────────────────────────────────────────────────────
.idea/
.vscode/
*.DS_Store
.git/
.gitignore

# ── Test files ────────────────────────────────────────────────────────────────
tests/
test_*.py
pytest.ini
